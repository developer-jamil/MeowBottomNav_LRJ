<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:layout="@layout/fragment_home" />

    <!-- Meow-style Bottom Navigation -->
    <com.etebarian.meowbottomnavigation.MeowBottomNavigation
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:mbn_backgroundBottomColor="@color/nav_bg"
        app:mbn_circleColor="@color/nav_circle"
        app:mbn_defaultIconColor="@color/nav_default_icon"
        app:mbn_selectedIconColor="@color/nav_selected_icon"
        app:mbn_rippleColor="@color/nav_ripple"
        app:mbn_hasAnimation="true" />

    <!-- Title labels aligned with each nav item -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nav_bg"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Home"
            android:textColor="@color/nav_circle"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvEarn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Earn"
            android:textColor="@color/nav_default_icon"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvPromote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Promote"
            android:textColor="@color/nav_default_icon"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvWallet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Wallet"
            android:textColor="@color/nav_default_icon"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Profile"
            android:textColor="@color/nav_default_icon"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>
